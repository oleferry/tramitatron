# Copia este fichero a .env y ajusta los valores. NUNCA subas .env al repo.

# Sesión efímera (segundos). PRD §13.1: 20 minutos.
SESSION_TTL_SECONDS=1200

# Redis para sesiones. Si se deja vacío, la API usa almacén en memoria (solo desarrollo).
# REDIS_URL=redis://localhost:6379/0

# PostgreSQL (usado a partir de la fase 4: métricas y versionado de catálogo).
POSTGRES_PASSWORD=cambia-esta-contrasena

# Orígenes permitidos para CORS (kiosco en desarrollo).
CORS_ORIGINS=http://localhost:5173

# Límite de peticiones por cliente y ventana (ENS mp.s.2). 0 desactiva.
# RATE_LIMIT_REQUESTS=240
# RATE_LIMIT_WINDOW_SECONDS=60

# Token del agente de periféricos (ENS op.acc). Si se define, imprimir/capturar/
# purgar exigen la cabecera X-Device-Token. Sin él, el agente queda abierto
# (solo desarrollo en localhost). Genera uno con: python -c "import secrets;print(secrets.token_urlsafe(24))"
# DEVICE_AGENT_TOKEN=

# Ruta del catálogo declarativo de trámites.
# CATALOG_PATH=./connectors/catalog

# --- Proveedor de IA (PRD §10) ------------------------------------------------
# Sin ANTHROPIC_API_KEY, el gateway es el mock y NO sale ningún dato de la
# máquina (regla 12: demo local reproducible). Requiere instalar el extra:
#   pip install -e ".[ai]"
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_PROVIDER=anthropic          # se autoactiva si hay clave; "mock" para forzar mock
# ANTHROPIC_MODEL=claude-opus-4-8
#
# Enviar imágenes de DNI/SIP y el texto de cartas (datos A2, PRD §13.2) a un
# proveedor externo requiere una decisión de arquitectura y EIPD (§10.4). Por
# eso va detrás de su propio interruptor y está DESACTIVADO por defecto: con el
# proveedor real, la extracción de documentos y el OCR de cartas siguen siendo
# mock hasta que se ponga a "true". La transcripción de voz nunca usa Claude
# (no hace STT de audio); sigue siendo mock. Ver docs/adr/ADR-006.
# ANTHROPIC_ALLOW_DOCUMENTS=false
